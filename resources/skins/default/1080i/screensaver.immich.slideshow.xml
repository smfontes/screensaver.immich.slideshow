<?xml version="1.0" encoding="UTF-8"?>
<window>
	<zorder>6</zorder>
	<controls>
		<control type="group">
			<top>0</top>
			<left>0</left>
			<width>1920</width>
			<height>1080</height>
			<control type="image">
				<description>Black image to put everything on top of</description>
				<texture>screensaver-black.png</texture>
				<animation effect="fade" start="0" end="100" time="500">WindowOpen</animation>
			</control>
			<control type="image" id="99">
			    <visible>false</visible>
			    <texture background="true"></texture>
			</control>
			<control type="group">
				<description>Background Images</description>
				<control type="image" id="3">
					<description>background image 1</description>
					<animation type="Conditional" condition="String.IsEqual(Window.Property(Screensaver.Background),0)">
						<effect type="fade" start="0" end="100" time="1000"/>
					</animation>
					<animation type="Conditional" condition="String.IsEqual(Window.Property(Screensaver.Background),1)">
						<effect type="fade" start="100" end="0" time="1000"/>
					</animation>
					<aspectratio>scale</aspectratio>
					<texture background="true" colordiffuse="40FFFFFF"></texture>
				</control>
				<control type="image" id="4">
					<description>background image 2</description>
					<animation type="Conditional" condition="String.IsEqual(Window.Property(Screensaver.Background),1)">
						<effect type="fade" start="0" end="100" time="1000"/>
					</animation>
					<animation type="Conditional" condition="String.IsEqual(Window.Property(Screensaver.Background),0)">
						<effect type="fade" start="100" end="0" time="1000"/>
					</animation>					
					<aspectratio>scale</aspectratio>
					<texture background="true" colordiffuse="40FFFFFF"></texture>
				</control>
			</control>
			<control type="image" id="1">
				<description>Image 1</description>
				<texture background="true"></texture>
				<aspectratio>keep</aspectratio>
			</control>
			<control type="image" id="2">
				<description>Image 2</description>
				<texture background="true"></texture>
				<aspectratio>keep</aspectratio>
			</control>
		</control>
		<control type="grouplist" id="100">
			<description>Information block</description>
			<left>15</left>
			<bottom>20</bottom>
			<width>1620</width>
			<height>880</height>
			<align>bottom</align>
			<textcolor>FFFFFFFF</textcolor>
			<itemgap>0</itemgap>
			<control type="button" id="101">
				<description>album</description>
				<animation type="Conditional" condition="String.IsEqual(Window.Property(Screensaver.Info),0)">
					<effect type="fade" start="0" end="100" time="1000"/>
				</animation>
				<animation type="Conditional" condition="String.IsEqual(Window.Property(Screensaver.Info),1) + !String.IsEqual(Window.Property(Screensaver.NoFade),1)">
					<effect type="fade" start="100" end="0" time="1000"/>
				</animation>
				<height>36</height>
				<width>auto</width>
				<align>left</align>
				<aligny>center</aligny>
				<visible>!String.IsEmpty(Window.Property(Screensaver.AlbumName0))</visible>
				<label>$INFO[Window.Property(Screensaver.AlbumName0)]</label>
				<texturenofocus colordiffuse="FF000000">screensaver-highlight.png</texturenofocus>
			</control>
			<control type="button" id="102">
