				<visible>Player.HasAudio + String.IsEqual(Window.Property(Screensaver.Music),show)</visible>
				<height>210</height>
				<control type="grouplist">
					<height>190</height>
					<left>210</left>
					<top>30</top>
					<align>left</align>
					<itemgap>0</itemgap>
					<control type="button">
						<width>auto</width>
						<height>38</height>
						<font>font13</font>
        				<shadowcolor>FF000000</shadowcolor>
						<label> [B]$INFO[MusicPlayer.Title][/B]</label>
						<texturenofocus colordiffuse="FF000000">screensaver-highlight.png</texturenofocus>
					</control>
					<control type="button">
						<width>auto</width>
						<height>38</height>
						<font>font13</font>
        				<shadowcolor>FF000000</shadowcolor>
						<label> $INFO[MusicPlayer.Artist]</label>
						<texturenofocus colordiffuse="FF000000">screensaver-highlight.png</texturenofocus>
					</control>
