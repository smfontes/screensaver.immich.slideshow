						<width>auto</width>
						<height>38</height>
						<font>font13</font>
        				<shadowcolor>FF000000</shadowcolor>
						<label> [I]$INFO[MusicPlayer.Album][/I]</label>
						<texturenofocus colordiffuse="FF000000">screensaver-highlight.png</texturenofocus>
					</control>
					<control type="button">
						<width>auto</width>
						<height>38</height>
						<font>font13</font>
        				<shadowcolor>FF000000</shadowcolor>
						<label> $INFO[Player.Time(hh:mm:ss)] / $INFO[Player.Duration(hh:mm:ss)]</label>
						<texturenofocus colordiffuse="FF000000">screensaver-highlight.png</texturenofocus>
					</control>
					<control type="button">
						<width>auto</width>
						<height>28</height>
        				<font>font10</font>
        				<shadowcolor>FF000000</shadowcolor>
        				<textcolor>FF888888</textcolor>
						<label> Next: [B]$INFO[MusicPlayer.offset(1).Title][/B] ($INFO[MusicPlayer.offset(1).Artist])</label>
						<texturenofocus colordiffuse="FF000000">screensaver-highlight.png</texturenofocus>
					</control>
				</control>
				<control type="image">
					<top>5</top>
					<width>210</width>
					<height>210</height>
					<texture fallback="DefaultAlbumCover.png">$INFO[MusicPlayer.Cover]</texture>
					<aspectratio>stretch</aspectratio>
				</control>
			</control>
